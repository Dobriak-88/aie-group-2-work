# Car Price Predictor – переменные окружения

# Путь к CSV-файлу с данями (по умолчанию src/data/cars.csv)
DATA_PATH=src/data/cars.csv

# Папка для сохранения модели и препроцессора (по умолчанию src/artifacts)
ARTIFACTS_PATH=src/artifacts

# Папка для логов (по умолчанию src/logs)
LOGS_PATH=src/logs

# Случайное зерно для воспроизводимости (по умолчанию 42)
RANDOM_STATE=42